# ---- REQUIRED ----
# MongoDB connection string. Use MongoDB Atlas (free tier works).
MONGO_URI=mongodb+srv://USER:PASSWORD@cluster0.example.mongodb.net/shadow_garden?retryWrites=true&w=majority

# Session signing secret (any long random string)
SESSION_SECRET=change-me-to-a-long-random-string

# Owner identity (your WhatsApp LID, e.g. 1234567890@lid)
BOT_OWNER_LID=1234567890@lid

# Command prefix (single character recommended)
PREFIX=.

# ---- KEEP-ALIVE ----
# Public URL of your Render service. The bot pings RENDER_URL/ping every 10
# minutes so the free instance never spins down.
# Example: https://shadow-garden-bot.onrender.com
RENDER_URL=https://your-service-name.onrender.com

# ---- OPTIONAL ----
# Set to "production" on Render
NODE_ENV=production

# Web port (Render injects this automatically)
PORT=10000

# If you want to use a real Postgres instead of the in-memory shim,
# set DATABASE_URL. Leave unset to use the bundled in-memory pg-mem.
# DATABASE_URL=postgres://user:pass@host:5432/dbname?sslmode=require
